# ── 部署打包产物(大体积二进制+含数据,不入库) ──
pmplatform-deploy-*.zip
# 升级/更新包构建产物（含 dist，本机生成，不入库）
release/

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# ── 打包产物 ──
build/
dist/

# ── 运行日志 ──
log/

# ── 生成物 / 抓取物 / 运行时数据（不入库，由脚本在本机生成）──
# analysis_data.json/.js 由 preprocess_data.py 生成（~2.2MB）；测试样本请放 tests/fixtures/
data/analysis_data.json
data/analysis_data.js
# yundocs_data/ 由 fetch_yundocs_full.py 抓取，含真实业务数据，不入库
yundocs_data/
# input/ 为用户放置/上传的真实数据（PMIS 七表、组织架构、项目映射、预算核算），不入库
input/
# 倚天导出（验证阶段）：cookie 凭据 + 导出数据不入库；脚本/说明可入库
yitian/config.json
yitian/downloads/
yitian/__pycache__/
# 快照与事件流（运行时生成，Phase P3）
data/snapshots/
data/events.json
# 数据历史版本（含真实源数据副本，运行时生成，不入库）
data/history/
# 人工数据导入快照（运行时生成，含本地用户数据，2E）
data/manual_backups/
# 本地跟进记录（运行时用户数据）
data/followup_records.json
# 项目标签库（运行时用户数据，2C）
data/project_tags.json
# 首页门户/快捷入口配置 + 上传文件（本地敏感数据，运行时生成，不入库）
data/portal_links.json
data/portal_files/
# 重点项目进展数据（运行时用户数据，SP-2）
data/project_progress.json
# 商机管理数据（运行时用户数据，V2.0.0）
data/opportunities.json
data/opportunities.backup-*.json
# 临时重点跟进数据(运行时用户数据,V2.1.0)
data/temp_followup.json
data/temp_followup.backup-*.json
# 本地账号库(含密码哈希,敏感,运行时生成,SP-2)
data/accounts.json
data/accounts.json.tmp
data/audit_log.jsonl
data/audit_log.jsonl.tmp
data/audit_archive/
# 回款比对报告（含真实业务数据，一次性诊断产物，不入库）
report/

# ── 前端（Vue/Vite）──
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
# schema.py 导出的中间产物（TS 类型生成用），不入库
schema.json
data/yitian_data.json
yitian_schema.json

