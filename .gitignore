# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# ── 打包产物 ──
build/
dist/

# ── 运行日志 ──
log/

# ── 生成物 / 抓取物 / 运行时数据（不入库，由脚本在本机生成）──
# analysis_data.json/.js 由 preprocess_data.py 生成（~2.2MB）；测试样本请放 tests/fixtures/
data/analysis_data.json
data/analysis_data.js
# yundocs_data/ 由 fetch_yundocs_full.py 抓取，含真实业务数据，不入库
yundocs_data/
# input/ 为用户放置/上传的真实数据（PMIS 七表、组织架构、项目映射、预算核算），不入库
input/
# 快照与事件流（运行时生成，Phase P3）
data/snapshots/
data/events.json
# 数据历史版本（含真实源数据副本，运行时生成，不入库）
data/history/
# 本地跟进记录（运行时用户数据）
data/followup_records.json
# 项目标签库（运行时用户数据，2C）
data/project_tags.json
# 回款比对报告（含真实业务数据，一次性诊断产物，不入库）
report/

# ── 前端（Vue/Vite）──
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo
# schema.py 导出的中间产物（TS 类型生成用），不入库
schema.json

# ── 系统 ──
.DS_Store
Thumbs.db

# ── 工具产物 ──
# brainstorming 可视化草图（本机临时）
.superpowers/
.vite/
# oh-my-claudecode 运行时状态/检查点（本机临时，不入库）
.omc/
# 根级 node_modules（若有）
/node_modules/
