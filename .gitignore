data/opportunities.backup-*.json
# 临时重点跟进数据(运行时用户数据,V2.1.0)
data/temp_followup.json
data/temp_followup.backup-*.json
# 本地账号库(含密码哈希,敏感,运行时生成,SP-2)
data/accounts.json
data/accounts.json.tmp
data/audit_log.jsonl
data/audit_log.jsonl.tmp
data/audit_archive/
# 回款比对报告（含真实业务数据，一次性诊断产物，不入库）
report/

